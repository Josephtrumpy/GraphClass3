import java.io.*;
import java.util.*;

public class Main
{
public static void main(String [] args) throws Exception
{
Graph g = new Graph();
Scanner input = new Scanner(new File("graph4.txt"));

while(input.hasNext())
{
String v1 = input.next();
String v2 = input.next();
g.addEdge(v1,v2);
}
input.close();
g.printAdjacencyList();

}
}
